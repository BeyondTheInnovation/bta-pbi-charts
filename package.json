{
  "name": "bta-pbi-charts",
  "packageManager": "bun@1.3.10",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:shared": "bun run --filter @pbi-visuals/shared build",
    "collect:dist": "bun run scripts/collect-dist.mjs",
    "build:all": "bun run build:shared && bun run --workspaces --if-present package && bun run collect:dist",
    "package:heatmap": "bun run --filter @pbi-visuals/heatmap package",
    "package:streamgraph": "bun run --filter @pbi-visuals/streamgraph package",
    "package:bump-chart": "bun run --filter @pbi-visuals/bump-chart package",
    "package:calendar": "bun run --filter @pbi-visuals/calendar-heatmap package",
    "package:bubble": "bun run --filter @pbi-visuals/packed-bubble package",
    "package:donut": "bun run --filter @pbi-visuals/donut-chart package",
    "package:bollinger": "bun run --filter @pbi-visuals/bollinger-bands package",
    "package:world-history": "bun run --filter @pbi-visuals/world-history-timeline package",
    "package:inline-labels": "bun run --filter @pbi-visuals/inline-labels-line package",
    "start:heatmap": "bun run --filter @pbi-visuals/heatmap start",
    "start:streamgraph": "bun run --filter @pbi-visuals/streamgraph start",
    "start:bump-chart": "bun run --filter @pbi-visuals/bump-chart start",
    "start:calendar": "bun run --filter @pbi-visuals/calendar-heatmap start",
    "start:bubble": "bun run --filter @pbi-visuals/packed-bubble start",
    "start:donut": "bun run --filter @pbi-visuals/donut-chart start",
    "start:bollinger": "bun run --filter @pbi-visuals/bollinger-bands start",
    "start:world-history": "bun run --filter @pbi-visuals/world-history-timeline start",
    "start:inline-labels": "bun run --filter @pbi-visuals/inline-labels-line start",
    "package:box-plot": "bun run --filter @pbi-visuals/box-plot package",
    "package:histogram": "bun run --filter @pbi-visuals/histogram package",
    "package:candlestick": "bun run --filter @pbi-visuals/candlestick-chart package",
    "package:parallel": "bun run --filter @pbi-visuals/parallel-coordinates package",
    "package:scatterplot-matrix": "bun run --filter @pbi-visuals/scatterplot-matrix package",
    "package:sankey": "bun run --filter @pbi-visuals/sankey-diagram package",
    "package:treemap": "bun run --filter @pbi-visuals/zoomable-treemap package",
    "package:sunburst": "bun run --filter @pbi-visuals/zoomable-sunburst package",
    "package:icicle": "bun run --filter @pbi-visuals/zoomable-icicle package",
    "package:choropleth": "bun run --filter @pbi-visuals/choropleth-map package",
    "package:chord": "bun run --filter @pbi-visuals/chord-diagram package",
    "package:waterfall": "bun run --filter @pbi-visuals/waterfall-chart package",
    "start:box-plot": "bun run --filter @pbi-visuals/box-plot start",
    "start:histogram": "bun run --filter @pbi-visuals/histogram start",
    "start:candlestick": "bun run --filter @pbi-visuals/candlestick-chart start",
    "start:parallel": "bun run --filter @pbi-visuals/parallel-coordinates start",
    "start:scatterplot-matrix": "bun run --filter @pbi-visuals/scatterplot-matrix start",
    "start:sankey": "bun run --filter @pbi-visuals/sankey-diagram start",
    "start:treemap": "bun run --filter @pbi-visuals/zoomable-treemap start",
    "start:sunburst": "bun run --filter @pbi-visuals/zoomable-sunburst start",
    "start:icicle": "bun run --filter @pbi-visuals/zoomable-icicle start",
    "start:choropleth": "bun run --filter @pbi-visuals/choropleth-map start",
    "start:chord": "bun run --filter @pbi-visuals/chord-diagram start",
    "start:waterfall": "bun run --filter @pbi-visuals/waterfall-chart start"
  },
  "dependencies": {},
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4"
  }
}
