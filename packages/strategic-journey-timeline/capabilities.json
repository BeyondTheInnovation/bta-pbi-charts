  "dataViewMappings": [
    {
      "conditions": [
        {
          "title": { "max": 1 },
          "subtitle": { "max": 1 },
          "group": { "max": 1 },
          "status": { "max": 1 },
          "lane": { "max": 1 },
          "startDate": { "max": 1 },
          "endDate": { "max": 1 },
          "milestoneDate": { "max": 1 },
          "sortOrder": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "select": [
            { "for": { "in": "title" } },
            { "for": { "in": "subtitle" } },
            { "for": { "in": "group" } },
            { "for": { "in": "status" } },
            { "for": { "in": "lane" } },
            { "for": { "in": "startDate" } },
            { "for": { "in": "milestoneDate" } },
            { "for": { "in": "endDate" } }
          ],
          "dataReductionAlgorithm": {
            "top": { "count": 30000 }
          }
        },
        "values": {
          "select": [
            { "for": { "in": "endDate" } },
            { "for": { "in": "sortOrder" } }
          ]
        }
      }
    }
  ],
  "supportsHighlight": true,
